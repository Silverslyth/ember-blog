{{- $index := slice -}}
{{- range .Site.RegularPages -}}
  {{- $index = $index | append (dict
    "title"       .Title
    "description" (or .Description .Summary)
    "url"         .Permalink
    "date"        (.Date.Format "Jan 2, 2006")
    "categories"  .Params.categories
    "tags"        .Params.tags
    "content"     (.Plain | truncate 300)
  ) -}}
{{- end -}}
{{- $index | jsonify -}}
